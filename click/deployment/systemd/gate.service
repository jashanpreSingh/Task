[Unit]
Description=JIVO Gate Management (Django)
After=network.target

[Service]
User=www-data
Group=www-data
WorkingDirectory=/var/www/teamboard/click
# Served under /gate/ behind nginx.
Environment=SCRIPT_PREFIX=/gate
# Optional: a gate-specific .env. If absent, settings.py falls back to the
# Team Board project .env (../.env) for DB credentials.
EnvironmentFile=-/var/www/teamboard/click/.env
ExecStart=/var/www/teamboard/click/.venv/bin/gunicorn config.wsgi:application --bind 127.0.0.1:8731 --workers 3 --timeout 60
Restart=always
RestartSec=5

[Install]
WantedBy=multi-user.target
